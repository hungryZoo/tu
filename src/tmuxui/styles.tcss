/* tu — a tiny session menu. */

Screen {
    align: center middle;
}

#root {
    width: 70;
    max-width: 90%;
    height: auto;
    max-height: 80%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

DataTable {
    height: 1fr;
    min-height: 6;
    max-height: 20;
    margin-bottom: 1;
}

#buttons {
    height: auto;
    align: center middle;
}

#buttons Button {
    margin: 0 1;
}
